// Cada cobertura = un profesional cubriendo un tramo [start, end] de la guardia.
// Una guardia puede tener varias coberturas (postuladas o compulsivas) y el
// coordinador puede aprobarla aunque queden huecos sin cubrir.
model ShiftCoverage {
  id                 String   @id @default(cuid())
  shiftReplacementId String
  applicantId        String
  start              DateTime
  end                DateTime
  origin             String   @default("POSTULATION") // POSTULATION | COMPULSORY
  createdAt          DateTime @default(now())

  shift     ShiftReplacement @relation(fields: [shiftReplacementId], references: [id], onDelete: Cascade)
  applicant User             @relation("CoverageApplicant", fields: [applicantId], references: [id])

  @@index([shiftReplacementId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}
